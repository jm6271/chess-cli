<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>chess_cli</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Version>0.2.0</Version>
    <AssemblyInformationalVersion>v0.2.0</AssemblyInformationalVersion>
    <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
    <PublishAot>true</PublishAot>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Gera.Chess" Version="1.2.0" />
    <PackageReference Include="System.CommandLine" Version="2.0.9" />
  </ItemGroup>

  <!-- Gera.Chess uses SmartEnum reflection to discover pieces/colors. Root both
       assemblies so NativeAOT does not trim those static instances. -->
  <ItemGroup>
    <TrimmerRootAssembly Include="ChessLibrary" />
    <TrimmerRootAssembly Include="Ardalis.SmartEnum" />
  </ItemGroup>

</Project>
